library(Rmolt)
library(Rmolt)
Rmolt <- function(data,primaries) {
primaries <<- primaries
if (primaries == 10){  #9 primaries
primarie_10(i,data)
}
if(primaries == 9){   #10 primaries
primarie_9(i,data)}
if(primaries == "10_0"){   #only 10 primaries
par(mar = c(0,0,0,0) + 0.1)
plot(1,1, col = "white", xlab = "", ylab = ""
,xlim=c(0,15), ylim=c(-2,25),axes= FALSE)
a <-0
b <- 1
c <- 0.5
d <- 15
e <- 1.2
polygon (x=c(0+e, 0+e, 1+e, 1+e, 0.5+e),
y=c(20, 22, 22, 20, 20),
col="white")
C1 <<- "white"
text(2.3, 23, "0%",cex=0.7)
C2 <-polygon (x=c(a+e*2, e*2+a, e*2+b, e*2+b, e*2+c),
y=c(20, 22, 22, 20, 20),
col="gray90")
C2 <<- "gray90"
text(2.3+e, 23, "5%",cex=0.7)
C3 <-polygon (x=c(a+e*3, e*3+a, e*3+b, e*3+b, e*3+c),
y=c(20, 22, 22, 20, 20),
col="gray80")
C3 <<- "gray80"
text(2.3+e*2, 23, "10%",cex=0.7)
C4 <-polygon (x=c(a+e*4, e*4+a, e*4+b, e*4+b, e*4+c),
y=c(20, 22, 22, 20, 20),
col="lightyellow3")
C4 <<- "lightyellow3"
text(2.3+e*3, 23, "25%",cex=0.7)
C5 <-polygon (x=c(a+e*5, e*5+a, e*5+b, e*5+b, e*5+c),
y=c(20, 22, 22, 20, 20),
col="gray57")
C5 <<- "gray57"
text(2.3+e*4, 23, "50%",cex=0.7)
C6 <-polygon (x=c(a+e*6, e*6+a, e*6+b, e*6+b, e*6+c),
y=c(20, 22, 22, 20, 20),
col="gray37")
C6 <<- "gray37"
text(2.3+e*5, 23, "75%",cex=0.7)
C7 <-polygon (x=c(a+e*7, e*7+a, e*7+b, e*7+b, e*7+c),
y=c(20, 22, 22, 20, 20),
col="gray20")
C7 <<- "gray20"
C8 <-polygon (x=c(a+e*8, e*8+a, e*8+b, e*8+b, e*8+c),
y=c(20, 22, 22, 20, 20),
col="gray0")
C8 <<- "gray0"
text(2.3+e*6, 23, "90%",cex=0.7)
text(2.3+e*7, 23, "100%",cex=0.7)
for(i in 1:9) {
moult_color(i,data)
P3 <-polygon (x=c(a+e*i, e*i+a, e*i+b, e*i+b, e*i+c),
y=c(b, d, d, b, a),
col=feather)
text(c+e*i, -1, data[i,1])
}
moult_color(i+1,data)
P10 <-polygon (x=c(a+e*(i+1), e*(i+1)+a, e*(i+1)+b, b+e*(i+1), c+e*(i+1)),
y=c(4, d, d, 4, 3),
col=feather)
text(c+e*i+1.2, 2, "P10")
}
}
